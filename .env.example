# Copy this to .env and fill in real values. Never commit .env to version control.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant   # or llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.
WHISPER_MODEL=base                 # tiny | base | small | medium
UPLOAD_DIR=/tmp/videorag           # where video files are temporarily stored
